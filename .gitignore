# ── Data (VitalDB tensors / raw signals — not distributed) ──
data/
*.npz
*.npy
*.pkl
*.pickle
*.h5
*.hdf5
*.csv

# ── Model checkpoints (regenerated by training) ──
checkpoints/
*.pt
*.pth
*.ckpt

# ── Archives ──
*.zip
*.tar.gz

# ── Logs & run outputs ──
logs/
*.log
runs/
wandb/
tensorboard/

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# ── Environments ──
.venv/
venv/
env/
.env
.envrc

# ── Papers / large binaries (kept out of the repo) ──
*.pdf
*.docx
*.pptx
# …but keep the project's own exhibition materials (poster / slides / report)
!docs/*.pdf

# ── macOS / IDE / Jupyter ──
.DS_Store
._*
.vscode/
.idea/
*.swp
*.swo
*~
.ipynb_checkpoints/
*.bak
*.tmp
